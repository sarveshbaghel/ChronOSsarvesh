# ============================================
# CivicFix Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/civicfix
# For local dev without Docker, use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./civicfix.db

# --- Redis (rate limiting) ---
REDIS_URL=redis://redis:6379/0

# --- S3 / MinIO (image storage) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=civicfix
S3_REGION=us-east-1

# --- Google Maps (reverse geocoding) ---
GOOGLE_MAPS_API_KEY=

# --- X / Twitter API (social posting) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- Firebase (optional auth) ---
FIREBASE_PROJECT_ID=

# --- JWT Auth ---
JWT_SECRET=supersecretkey-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- App Config ---
MOCK_MODE=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=3600

# --- Admin Seed ---
ADMIN_EMAIL=admin@civicfix.com
ADMIN_PASSWORD=admin123
